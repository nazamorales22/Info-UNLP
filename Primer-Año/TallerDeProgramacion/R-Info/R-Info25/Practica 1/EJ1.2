programa ejemplo
procesos
  proceso juntarF(ES f: numero; ES esf: numero)
  comenzar
    si (~HayFlorEnLaEsquina)
      esf:= esf + 1
    sino
      mientras (HayFlorEnLaEsquina)
        tomarFlor
        f:=f+1
  fin 
  proceso DepositarFlores(ES f: numero)
  comenzar
    mientras (HayFlorEnLaBolsa)
      depositarFlor
  fin
  proceso recorrerAvenida(ES f: numero; ES esf:numero)
  comenzar
    repetir 99
      juntarF(f,esf)
      mover
    juntarF(f,esf)
    DepositarFlores(f)
    Informar('Flores ', f )
    Informar(' ESquinas sin Flores ', esf)
  fin
areas
  calle1: AreaP(1,1,1,100)
  calle3: AreaP(3,1,3,100)
  calle5: AreaP(5,1,5,100)
robots
  robot robot1
  variables
    f:numero
    esf:numero
  comenzar
    f:=0
    esf := 0
    recorrerAvenida(f,esf)
  fin
variables
  R_info: robot1
  R_info1: robot1
  R_info2:robot1
comenzar
  AsignarArea(R_info, calle1)
  AsignarArea(R_info1, calle3)
  AsignarArea(R_info2, calle5) 
  Iniciar(R_info, 1,1)
  Iniciar(R_info1, 3,1)
  Iniciar(R_info2, 5,1)
fin
