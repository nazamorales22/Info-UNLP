{Bienvenidos al entorno CMRE.
Lo siguiente es un código de ejemplo que implementa un
proceso que recibe un número de avenida como parámetro,
se posiciona en esa avenida y la recorre.}

programa ejemplo
procesos
  proceso JuntarF(ES f: numero)
  comenzar
    mientras HayFlorEnLaEsquina
      tomarFlor
      f:=f+1
  fin
  proceso JuntarP(ES p: numero)
  comenzar
    mientras HayPapelEnLaEsquina
      tomarPapel
      p:=p+1
  fin
  proceso recorrerAvenidaF(ES f : numero)
  variables
    avIni:numero
    caIni:numero
  comenzar
    avIni:=PosAv
    caIni:=PosCa
    repetir 24
      repetir 99
        JuntarF(f)
        mover
      JuntarF(f)
      avIni:=avIni+1
      Pos(avIni,caIni)
    repetir 99
      JuntarF(f)
      mover
    JuntarF(f)     
  fin
  proceso recorrerAvenidaP(ES p: numero)
  variables
    avIni:numero
    caIni:numero
  comenzar
    avIni:=PosAv
    caIni:=PosCa
    repetir 24
      repetir 99
        JuntarP(p)
        mover
      JuntarP(p)
      avIni:=avIni+1
      Pos(avIni,caIni) 
    repetir 99
      JuntarP(p)
      mover
    JuntarP(p)    
  fin
areas
  ciudad1: AreaP (1,1,25,100)
  ciudad2: AreaP (26,1,50,100)
  ciudad3: AreaP (51,1,75,100)
  ciudad4: AreaP (76,1,100,100)
robots
  robot robot1
  variables
    f:numero
  comenzar
    f:=0
    recorrerAvenidaF(f)
    Pos(51,1)
    recorrerAvenidaF(f)
  fin
  robot robot2
  variables
    p:numero
  comenzar
    p:=0
    recorrerAvenidaP(p)
    Pos(76,1)
    recorrerAvenidaP(p)
  fin
variables
  R1: robot1
  R2: robot2
comenzar
  AsignarArea(R1, ciudad1)
  AsignarArea(R1, ciudad3)
  AsignarArea(R2, ciudad2)
  AsignarArea(R2, ciudad4)
  Iniciar(R1, 1,1)
  Iniciar(R2,26,1)
fin