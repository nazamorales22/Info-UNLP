{Bienvenidos al entorno CMRE.
Lo siguiente es un cÃ³digo de ejemplo que implementa un
proceso que recibe un nÃºmero de avenida como parÃ¡metro,
se posiciona en esa avenida y la recorre.}

programa ejemplo
procesos
  proceso JuntarP(ES p: numero)
  comenzar
    mientras HayPapelEnLaEsquina
      tomarPapel
      p:=p+1
  fin
  proceso izquierda
  comenzar
    repetir 3
      derecha
  fin
areas
  c1: AreaP (10,10,10,29)
  c2: AreaP (10,30,29,30)
  c3: AreaP (30,11,30,30)
  c4: AreaP (11,10,30,10)
robots
  robot robot1
  variables
    p:numero
  comenzar
    p:=0
    repetir 19
      JuntarP(p)
      mover
    JuntarP(p)
    Informar('Total Papeles', p)
  fin
  robot robot2
  variables
    p:numero
  comenzar
    p:=0
    derecha
    repetir 19
      JuntarP(p)
      mover
    JuntarP(p)
    Informar('Total Papeles', p)
  fin
  robot robot3
  variables
    p:numero
  comenzar
    p:=0
    derecha
    derecha
    repetir 19
      JuntarP(p)
      mover
    JuntarP(p)
    Informar('Total Papeles', p)
  fin
  robot robot4
  variables
    p:numero
  comenzar
    p:=0
    izquierda
    repetir 19
      JuntarP(p)
      mover
    JuntarP(p)
    Informar('Total Papeles', p)
  fin
variables
  R_info: robot1
  R2: robot2
  R3:robot3
  R4:robot4
comenzar
  AsignarArea(R_info, c1)
  AsignarArea(R2, c2)
  AsignarArea(R3, c3)
  AsignarArea(R4, c4)
  Iniciar(R_info, 10,10)
  Iniciar(R2, 10,30)
  Iniciar(R3, 30,30)
  Iniciar(R4, 30,10)
fin