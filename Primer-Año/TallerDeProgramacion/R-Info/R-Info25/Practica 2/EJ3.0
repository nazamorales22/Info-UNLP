{Bienvenidos al entorno CMRE.
Lo siguiente es un código de ejemplo que implementa un
proceso que recibe un número de avenida como parámetro,
se posiciona en esa avenida y la recorre.}

programa ejemplo
procesos
  proceso JuntarF(ES f: numero)
  comenzar
    mientras HayFlorEnLaEsquina
      tomarFlor
      f:=f+1
  fin
  proceso JuntarP(ES p: numero)
  comenzar
    mientras HayPapelEnLaEsquina
      tomarPapel
      p:=p+1
  fin
  proceso recorridoA1(ES p: numero)
  comenzar
    repetir 9
      JuntarP(p)
      mover
    JuntarP(p) 
    EnviarMensaje(p,A2)     
  fin
  proceso recorridoA2(ES p: numero)
  comenzar
    RecibirMensaje(p,A1)
    repetir 9
      JuntarP(p)
      mover
    JuntarP(p) 
    Informar('Total papeles',p)
        
  fin
  proceso recorridoB1(ES f: numero)
  comenzar
    repetir 9
      JuntarF(f)
      mover
    JuntarF(f)
    EnviarMensaje(f,B2)
  fin
  proceso recorridoB2(ES f: numero)
  comenzar
    RecibirMensaje(f,B1)
    repetir 9
      JuntarF(f)
      mover
    JuntarF(f)
    Informar('Total flores ',f)
  fin
areas
  l1:AreaP(1,1,1,10)
  l2:AreaP(1,11,1,20)
  l3:AreaP(5,1,5,10)
  l4:AreaP(5,11,5,20)
robots
  robot robot1
  variables
    p:numero
  comenzar
    recorridoA1(p)
  fin
  robot robot2
  variables
    p:numero
  comenzar
    recorridoA2(p)
  fin
  robot robot3
  variables
    f:numero
  comenzar
    recorridoB1(f)
  fin
  robot robot4
  variables
    f:numero
  comenzar
    recorridoB2(f)
  fin
variables
  A1: robot1
  A2: robot2
  B1: robot3
  B2: robot4
comenzar
  AsignarArea(A1, l1)
  AsignarArea(A2, l2)
  AsignarArea(B1, l3)
  AsignarArea(B2, l4)
  Iniciar(A1, 1,1)
  Iniciar(A2, 1,11)
  Iniciar(B1, 5,1)
  Iniciar(B2, 5,11)
  
fin