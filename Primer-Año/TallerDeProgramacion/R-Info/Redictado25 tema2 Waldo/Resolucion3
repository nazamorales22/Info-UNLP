robots
  robot robot1
  variables
    id,f,p,pasos,av,caIni:numero
    termine,etapa2,finetapa2:boolean
  comenzar
    RecibirMensaje(id,RF)
    termine:=F
    av:=10
    caIni:=PosCa
    derecha
    EnviarMensaje(id,RF)
    EnviarMensaje(termine,RF)
    mientras termine =F
      RecibirMensaje(pasos,RF)
      repetir pasos
        mover
      juntarF(f)
      av:=av+pasos
      si av>=20
        termine :=V
      EnviarMensaje(id,RF)
      EnviarMensaje(termine,RF)
    Pos(25,caIni) 
    termine:=F
    av:=25
    RecibirMensaje(etapa2,RF)
    EnviarMensaje(id,RF)
    EnviarMensaje(termine,RF)
    mientras termine =F
      RecibirMensaje(pasos,RF)
      repetir pasos
        mover
      juntarF(f)
      av := av + pasos
      si (av > 40)
        termine :=V
      EnviarMensaje(id,RF)
      EnviarMensaje(termine,RF)
    RecibirMensaje(finetapa2,RF)
  fin
  robot robot2
  variables
    id,ganador,ganador1,ganador2,cant,pasos:numero
    termino:boolean 
  comenzar
    EnviarMensaje(1,R1)
    EnviarMensaje(2,R2)
    EnviarMensaje(3,R3)
    EnviarMensaje(4,R4)
    repetir 2
      ganador1:=ganador2
      cant:=0
      mientras cant<4 
        RecibirMensaje(id,*)
        si id =1
          RecibirMensaje(termino,R1)
          si termino =F
            Random(pasos,1,3)
            EnviarMensaje(pasos,R1)
          sino
            si cant=0
              ganador:=id
            cant:=cant+1
        sino
          si id =2
            RecibirMensaje(termino,R2)
            si termino=F
              Random(pasos,1,3)
              EnviarMensaje(pasos,R2)
            sino
              si cant=0
                ganador:=id
              cant:=cant+1
          sino
            si id =3
              RecibirMensaje(termino,R3)
              si termino=F
                Random(pasos,1,3)
                EnviarMensaje(pasos,R3) 
              sino
                si cant=0
                  ganador:=id
                cant:=cant+1
            sino
              si id = 4
                RecibirMensaje(termino,R4)
                si termino=F
                  Random(pasos,1,3)
                  EnviarMensaje(pasos,R4)
                sino
                  si cant=0
                    ganador:=id
                  cant:=cant+1
      ganador2:=ganador 
      EnviarMensaje(V,R1) 
      EnviarMensaje(V,R2)
      EnviarMensaje(V,R3)
      EnviarMensaje(V,R4) 
    Informar('primero primera etapa ',ganador1)  
    Informar('primero segunda etapa ',ganador2) 
  fin
