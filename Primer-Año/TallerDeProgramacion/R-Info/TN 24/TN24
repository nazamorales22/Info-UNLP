{Bienvenidos al entorno CMRE.
Lo siguiente es un código de ejemplo que implementa un
proceso que recibe un número de avenida como parámetro,
se posiciona en esa avenida y la recorre.}

programa ejemploTN
procesos
  proceso juntarP(ES p:numero)
  comenzar
    mientras HayPapelEnLaEsquina
      tomarPapel
      p:=p+1
  fin
  proceso izquierda
  comenzar
    derecha
    derecha
    derecha
  fin
  proceso escalon(ES p: numero;E alto:numero;E ancho:numero)
  comenzar
    repetir alto
      juntarP(p)
      mover
    derecha
    si ancho >1
      repetir ancho-1
        juntarP(p)
        mover
      juntarP(p)
      mover
    sino
      juntarP(p)
      mover 
    izquierda
  fin
  proceso depositar(E p:numero; E av:numero;E ca:numero)
  comenzar
    BloquearEsquina(100,100)
    Pos(100,100)
    repetir p
      depositarPapel
    Pos(av,ca)
    LiberarEsquina(100,100)
  fin
areas
  depo:AreaC(100,100,100,100)
  ar1:AreaP(2,1,14,15)
  ar2:AreaP(32,1,44,15)
  ar3:AreaP(62,1,72,15)
  arf:AreaP(1,1,1,1)
robots
  robot robot1
  variables
    id,alto,ancho,p,av,ca:numero
  comenzar
    RecibirMensaje(id,RF)
    RecibirMensaje(alto,RF)
    RecibirMensaje(ancho,RF)
    repetir 3
      escalon(p,alto,ancho)
    av:=PosAv
    ca:=PosCa
    depositar(p,av,ca)
    EnviarMensaje(id,RF)
    EnviarMensaje(p,RF)
      
  
  fin
  robot robot2
  variables
    id,alto,ancho,p,p1,p2,p3,ganador,max:numero
  comenzar
    max:=-1
    EnviarMensaje(1,R1)
    EnviarMensaje(2,R2)
    EnviarMensaje(3,R3)
    Random(alto,1,4)
    Random(ancho,1,3)
    EnviarMensaje(alto,R1)
    EnviarMensaje(ancho,R1)
    Random(alto,1,4)
    Random(ancho,1,3)
    EnviarMensaje(alto,R2)
    EnviarMensaje(ancho,R2)
    Random(alto,1,4)
    Random(ancho,1,3)
    EnviarMensaje(alto,R3)
    EnviarMensaje(ancho,R3)
    repetir 3
      RecibirMensaje(id,*)
      si id=1
        RecibirMensaje(p1,R1)
      sino
        si id=2
          RecibirMensaje(p2,R2)
        sino
          RecibirMensaje(p3,R3)
    si p1>max
      max:=p1
      ganador:=1
    si p2>max
      max:=p2
      ganador:=2
    si p3>max
      max:=p3
      ganador:=3
    Informar('el que junto mas papeles es ',ganador)
  fin
variables
  R1: robot1
  R2: robot1
  R3: robot1
  RF: robot2
comenzar
  AsignarArea(R1, ar1)
  AsignarArea(R2, ar2)
  AsignarArea(R3, ar3)
  AsignarArea(RF, arf)
  AsignarArea(R1, depo)
  AsignarArea(R2, depo)
  AsignarArea(R3, depo)
  Iniciar(RF, 1,1)
  Iniciar(R1, 2,1)
  Iniciar(R2, 32,1)
  Iniciar(R3, 62,1)
fin