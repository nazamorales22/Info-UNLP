programa ParcialT2030624
procesos
  proceso JuntarF(ES f: numero)
  comenzar
    mientras HayFlorEnLaEsquina
      tomarFlor
      f:=f+1
  fin
  proceso JuntarP(ES p: numero)
  comenzar
    mientras HayPapelEnLaEsquina
      tomarPapel
      p:=p+1
  fin
  proceso recorrerida(ES f: numero)
  comenzar
    repetir 4
      JuntarF(f)
      mover
  fin
  proceso recorrervuelta( ES p:numero)
  comenzar
    repetir 4
      JuntarP(p)
      mover
  fin
  proceso giro
  comenzar
    derecha
    derecha
  fin
areas
  ar1: AreaP (1,5,5,5)
  ar2: AreaP(1,7,5,7)
  aj: AreaP (1,6,1,6)
  acom: AreaPC(6,6,6,6)
  ar12: AreaP(7,7,11,7)
  ar21: AreaP (7,5,11,5)
robots
  robot robot1
  variables
    id,f,p,avVuelta,caVuelta:numero
  comenzar
    f:=0
    p:=0
    RecibirMensaje(id,RF)
    derecha
    recorrerida(f)
    avVuelta:=PosAv
    caVuelta:=PosCa
    BloquearEsquina(6,6)
    Pos(6,6)
    si HayFlorEnLaEsquina
      tomarFlor
      f:=f+1
    si id=1
      Pos(7,7)
    sino
      Pos(7,5)
    LiberarEsquina(6,6)
    recorrerida(f)
    EnviarMensaje(id,RF)
    EnviarMensaje(f,RF)
    giro
    recorrervuelta(p)
    BloquearEsquina(6,6)
    Pos(6,6)
    si HayPapelEnLaEsquina
      tomarPapel
      p:=p+1
    Pos(avVuelta,caVuelta)
    LiberarEsquina(6,6)
    recorrervuelta(p)
    EnviarMensaje(id,RF)
    EnviarMensaje(p,RF)
    
  fin
  robot robot2
  variables
    id,max,maxid,f,p:numero
  comenzar
    max:=0
    EnviarMensaje(1,R1)
    EnviarMensaje(2,R2)
    repetir 2
      RecibirMensaje(id,*)
      si id=1
        RecibirMensaje(f,R1)
        si f > max
          max :=f
          maxid :=id
      sino
        RecibirMensaje(f,R2)
        si f>max
          max:=f
          maxid:=id 
    Informar('flores', max)
    Informar('ganador', maxid)
    max:=0
    repetir 2
      RecibirMensaje(id,*)
      si id=1
        RecibirMensaje(p,R1)
        si p > max
          max :=p
          maxid :=id
      sino
        RecibirMensaje(p,R2)
        si p>max
          max:=p
          maxid:=id
    Informar('papeles', max)
    Informar('ganador', maxid)
  fin
variables
  R1: robot1
  R2: robot1
  RF: robot2
comenzar
  AsignarArea(R1, ar1)
  AsignarArea(R1, ar12)
  AsignarArea(R2, ar2)
  AsignarArea(R2, ar21)
  AsignarArea(R1, acom)
  AsignarArea(R2, acom)
  AsignarArea(RF, aj)
  Iniciar(R1,1,5)
  Iniciar(R2,1,7)
  Iniciar(RF,1,6)
fin