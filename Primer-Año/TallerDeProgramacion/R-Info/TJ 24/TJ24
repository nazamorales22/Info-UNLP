  AsignarArea(RJ,depF)
  AsignarArea(R1,depP)
  AsignarArea(R1,depF)
  AsignarArea(R2,depP)
  AsignarArea(R2,depF)
  AsignarArea(R3,depP)
  AsignarArea(R3,depF)
  Iniciar(RJ, 1,1)
  Iniciar(R1, 2,1)
