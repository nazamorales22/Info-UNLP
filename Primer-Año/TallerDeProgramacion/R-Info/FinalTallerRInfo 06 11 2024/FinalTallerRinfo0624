robots
  robot robot1
  variables
    id,av,ca,obj:numero
    listo:boolean  
  comenzar
    RecibirMensaje(id,RF)
    av:=PosAv
    ca:=PosCa
    irFuente(obj,av,ca,id)
    etapaDos(obj,av,ca,id)
    si obj=1
      depositar(av,ca,id)
      EnviarMensaje(id,RF)
      EnviarMensaje(V,RF)
  fin

  robot robot2
  variables
    id,ganador:numero
    listo:boolean
  comenzar
    EnviarMensaje(1,R1)
    EnviarMensaje(2,R2)
    RecibirMensaje(id,*)
    si id=1
      RecibirMensaje(listo,R1)
      ganador:=id
      RecibirMensaje(id,R2)
      RecibirMensaje(listo,R2)
    sino 
      RecibirMensaje(listo,R2)
      ganador:=id
      RecibirMensaje(id,R1)
      RecibirMensaje(listo,R1)  
    Informar('El Ganador Fue  ', ganador)
  fin
variables
  R1: robot1
  R2: robot1
  RF: robot2
comenzar
  AsignarArea(R1, base1)
