programa ejemplo
procesos
  proceso irFuente(ES obj: numero;E av:numero;E ca:numero; E id:numero)
  variables
    avd,cad:numero
  comenzar
    repetir 5
      si id=1
        BloquearEsquina(18,13)
        Pos(18, 13) 
        tomarFlor
        Pos(av,ca)
        LiberarEsquina(18,13)
        Random(avd,11,15)
        Random(cad,11,15)
        BloquearEsquina(avd,cad)
        Pos(avd,cad)
        depositarFlor
        Pos(av,ca)
        LiberarEsquina(avd,cad)
      sino 
        si id=2
          BloquearEsquina(18,13)
          Pos(18, 13) 
          tomarPapel
          Pos(av,ca)
          LiberarEsquina(18,13)
          Random(avd,21,25)
          Random(cad,11,15)
          BloquearEsquina(avd,cad)
          Pos(avd,cad)
          depositarPapel
          Pos(av,ca)
          LiberarEsquina(avd,cad)
  fin
  proceso etapaDos(ES obj:numero;E av:numero; E ca:numero; E id:numero)
  variables
    avb,cab:numero
    termino:boolean
  comenzar
    termino:=F
    mientras termino=F
      si id=1
        Random(avb,21,25)
        Random(cab,11,15)
        BloquearEsquina(avb,cab)
        Pos(avb,cab)
        si HayPapelEnLaEsquina 
          tomarPapel
          obj:=obj+1
          termino:=V
        Pos(av,ca)
        LiberarEsquina(avb,cab)
      sino
        si id=2
          Random(avb,11,15)
          Random(cab,11,15)
          BloquearEsquina(avb,cab)
          Pos(avb,cab)
          si HayFlorEnLaEsquina
            tomarFlor
            obj:=obj+1
            termino:=V
          Pos(av,ca)
          LiberarEsquina(avb,cab)
  fin
  proceso depositar(E av:numero; E ca:numero; E id:numero)
  comenzar
    si id=1
      BloquearEsquina(18,13)
      Pos(18, 13) 
      depositarPapel
      Pos(av,ca)
      LiberarEsquina(18,13)
    sino
      si id=2
        BloquearEsquina(18,13)
        Pos(18, 13) 
        depositarFlor
        Pos(av,ca)
        LiberarEsquina(18,13)
  fin
areas
  area1: AreaC (11,11,15,15)
  area2: AreaC (21,11,25,15)
