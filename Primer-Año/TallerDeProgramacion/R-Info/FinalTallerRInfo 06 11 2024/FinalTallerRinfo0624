  AsignarArea(R1, area2)
  AsignarArea(R1, fuente)
  AsignarArea(R2, fuente) 
  AsignarArea(RF, area3) 
  Iniciar(R1, 2,2) 
  Iniciar(R2, 3,3) 
  Iniciar(RF, 1,1)
fin 