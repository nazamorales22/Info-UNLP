programa ejemploTD
procesos
  proceso depositarF(ES f:numero)
  comenzar
    si ~HayFlorEnLaEsquina
      si HayFlorEnLaBolsa
        depositarFlor
        f:=f+1 
  fin
  proceso depositarP(ES p:numero)
  comenzar
    si ~HayPapelEnLaEsquina
      si HayPapelEnLaBolsa
        depositarPapel
        p:=p+1
  fin
  proceso recorrerAvenida(ES f:numero; E avFlo:numero)
  variables
    av,ca,carp1,carp2:numero
  comenzar
    carp1:=8
    carp2:=15
    ca:=PosCa
    mientras ca< 99
      si ((ca <> (carp1-1)) y (ca <> (carp2-1)))
        depositarF(f)
        mover
        ca:=ca+1
      sino 
        si (ca = (carp1-1))
          depositarF(f)
          BloquearEsquina(avFlo,carp1)
          mover
          depositarF(f)
          mover 
          LiberarEsquina(avFlo,carp1)
          ca:=ca+2
        sino
          si (ca =(carp2-1))
            depositarF(f)
            BloquearEsquina(avFlo,carp2)
            mover
            depositarF(f)
            mover 
            LiberarEsquina(avFlo,carp2)
            ca:=ca+2
    mover
    depositarF(f)
  fin
  proceso recorrerCalle(ES p:numero; E avFlo:numero)
  variables
    av,ca:numero
  comenzar 
    av:=PosAv
    ca:=PosCa
    mientras av <99
      si(av <> (avFlo-1))
        depositarP(p)
        mover
        av:=av+1
      sino
        depositarP(p)
        BloquearEsquina(avFlo,ca)
        mover
        depositarP(p)
        mover 
        LiberarEsquina(avFlo,ca)
        av:=av+2
    mover
    depositarP(p)   
  fin
areas
  cj: AreaP(1,1,1,1)
  c2:AreaP(1,2,1,2)
  cflo: AreaPC (2,1,35,100)
  c8: AreaP(1,8,100,8)
  c15: AreaP(1,15,100,15)
robots
  robot robot1
  variables
    id,avFlo,caFlo,avini,caini,objeto:numero
    ok: boolean
  comenzar
    objeto:=0
    RecibirMensaje(id,RJ)
    avini:=PosAv
    caini:=PosCa
    si (id=1)
      mientras HayFlorEnLaEsquina
        tomarFlor
      caFlo:=1
      RecibirMensaje(avFlo,RJ)
      Pos(avFlo,caFlo)
      recorrerAvenida(objeto,avFlo)
    sino
      mientras HayPapelEnLaEsquina
        tomarPapel 
      RecibirMensaje(avFlo,RJ)
      derecha
      recorrerCalle(objeto,avFlo)
    EnviarMensaje(id,RJ)
    
    RecibirMensaje(ok,RJ)
    si ok=V
      EnviarMensaje(objeto,RJ)
      Pos(avini,caini)
  fin
  robot robot2
  variables
    avFlorero,id,objeto,ganador,objganador,objp:numero
  comenzar
    EnviarMensaje(1,RF)
    EnviarMensaje(2,RP1)
    EnviarMensaje(3,RP2)
    Random(avFlorero,2,35)
    EnviarMensaje(avFlorero,RF)
    EnviarMensaje(avFlorero,RP1)
    EnviarMensaje(avFlorero,RP2)
    RecibirMensaje(id,*)
    ganador:=id
    si id=1
      RecibirMensaje(id,RP1)
      RecibirMensaje(id,RP2)
    sino 
      si id=2
        RecibirMensaje(id,RF)
        RecibirMensaje(id,RP2)
      sino
        RecibirMensaje(id,RF)
        RecibirMensaje(objp,RP1)
    si ganador=1
      EnviarMensaje(V,RF)
      EnviarMensaje(F,RP1)
      EnviarMensaje(F,RP2)
      RecibirMensaje(objganador,RF) 
    sino
      si ganador=2  
        EnviarMensaje(F,RF)
        EnviarMensaje(V,RP1)
        EnviarMensaje(F,RP2)
        RecibirMensaje(objganador,RP1)
      sino
        EnviarMensaje(F,RF)
        EnviarMensaje(F,RP1)
        EnviarMensaje(V,RP2) 
        RecibirMensaje(objganador,RP2)
    Informar('cantidad sembrada por ganador ', objganador)
  fin
