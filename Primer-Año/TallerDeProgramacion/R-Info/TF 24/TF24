  AsignarArea(RJ, aj)
  AsignarArea(RJ, adep)
  AsignarArea(R1, adep)
  AsignarArea(R2, adep)
  AsignarArea(R3, adep)
  AsignarArea(R4, adep)
  Iniciar(R1, 1,1)
  Iniciar(R2, 11,10)
  Iniciar(R3, 13,1)
  Iniciar(R4, 23,10)
  Iniciar(RJ, 30,1)
fin